rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /reviews/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if false;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /returns/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wishlist/{userId}/items/{productId} {
      allow read, write: if isOwner(userId);
    }

    match /notifications/{userId}/items/{notifId} {
      allow read, write: if isOwner(userId);
    }

    match /admin_transactions/{id} {
      allow read, write: if isAdmin();
    }

    match /admin_notifications/{id} {
      allow read, write: if isAdmin();
    }

    match /payout_requests/{id} {
      allow read, write: if isAdmin();
    }

    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }
  }
}
