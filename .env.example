# Flask
FLASK_SECRET_KEY=generate-a-long-random-string

# Firebase (Web SDK — configure in Firebase Console → Project settings → Your apps)
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=1:your-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin (server only — path to service account JSON downloaded from Firebase)
# Store the JSON outside this repo or ensure it is listed in .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json

# Cloudinary — images (optional overrides)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-upload-preset
CLOUDINARY_FOLDER=your-folder

# Razorpay (India)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional: scripts/bootstrap_admin.py (one-time local admin user)
# BOOTSTRAP_ADMIN_EMAIL=you@example.com
# BOOTSTRAP_ADMIN_PASSWORD=choose-a-strong-password

# Optional: scripts/seed_cloudinary_firestore.py — path to a local image to upload
# SEED_LOCAL_IMAGE_PATH=/path/to/sample.jpg
